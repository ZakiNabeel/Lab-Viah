# RishtaAI backend env vars.
# Copy to .env locally. Never commit .env.

# ---- Server ----
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ---- Supabase ----
# Project URL — ONLY the base, no path. Format: https://<ref>.supabase.co
# Do NOT include /rest/v1/ (that's the PostgREST sub-path; the client appends
# its own sub-paths for /auth/v1/, /storage/v1/, etc.). Pasting /rest/v1/ here
# silently breaks Auth even though DB queries appear to work. The config layer
# auto-strips /rest/v1 to protect against this, but please paste the clean URL.
SUPABASE_URL=
# Service-role key (server-side only — bypasses RLS). Do NOT expose to client.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key (used for OTP flow that the client would also use).
SUPABASE_ANON_KEY=
# JWT secret for verifying tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=

# ---- Vertex AI (Gemini) ----
# Gemini runs on Vertex AI (GCP-billed), NOT Google AI Studio. The AI Studio
# free tier clamps Gemini 3 Pro to quota=0, which is why we switched. Vertex
# Gemini 2.5/3 Pro is ~$1.25/M input + $10/M output tokens; a hackathon-scale
# workload costs well under $1.
#
# Auth: Application Default Credentials reads GOOGLE_APPLICATION_CREDENTIALS
# below. The service account needs the `Vertex AI User` IAM role on the
# project (roles/aiplatform.user). Enable the `aiplatform.googleapis.com` API.
GCP_PROJECT_ID=
# us-central1 has the broadest model availability. asia-south1 (Mumbai) is
# lower-latency for Pakistan users but supports fewer preview models.
GCP_LOCATION=us-central1
# Vertex uses explicit versioned model names — no *-latest aliases. Defaults
# are GA. Opt into `gemini-3-pro-preview` or similar if your project has
# access.
VERTEX_MODEL_PRIMARY=gemini-2.5-pro
VERTEX_MODEL_FALLBACK=gemini-2.5-flash

# ---- Google Cloud (STT + TTS + Maps + Vertex) ----
# Path to the service-account JSON file. Used by Vertex AI, Cloud Speech,
# Cloud TTS — anything ADC-aware. Must point at a JSON whose service account
# has `Vertex AI User` role on GCP_PROJECT_ID above.
GOOGLE_APPLICATION_CREDENTIALS=
# Alternative for Railway / PaaS: paste the FULL service-account JSON as a
# single env var value (Railway supports multi-line secrets). When this is
# set and GOOGLE_APPLICATION_CREDENTIALS is NOT set, the backend writes the
# JSON to a temp file at startup and sets GOOGLE_APPLICATION_CREDENTIALS
# automatically. Leave unset for local dev (use the file path above instead).
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_MAPS_API_KEY=

# ---- Trace / debug ----
# When true, writes a JSONL copy of every trace to ./traces/.
TRACE_DUMP_TO_FILE=false

# ---- Dev OTP bypass ----
# Phone OTP on Supabase requires a third-party SMS provider (Twilio etc).
# Until Twilio is wired up, set DEV_OTP_BYPASS=true to unlock /auth/otp/verify
# with a fixed phone+code pair. The bypass creates a real Supabase auth user
# via the admin API and returns a real Supabase JWT — same shape and same
# RLS behaviour as production OTP. MUST be false in production.
DEV_OTP_BYPASS=true
DEV_OTP_PHONE=+923001234567
DEV_OTP_CODE=123456
# Strong password used to back the dev auth user. Generate fresh per project:
#   openssl rand -base64 32
DEV_OTP_PASSWORD=
