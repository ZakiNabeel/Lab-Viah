{
  "name": "rishtaai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "RishtaAI backend — 8-agent matchmaking orchestrated inside Google Antigravity. Google Antigravity Hackathon 2026, Challenge 2.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx --env-file=.env src/db/seed-candidates.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@google/genai": "^1.0.0",
    "@supabase/supabase-js": "^2.45.4",
    "fastify": "^4.28.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
